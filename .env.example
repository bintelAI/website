# ============================================
# 维表智联 (Dimens) SDK 环境变量配置
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ---------- Dimens SDK 基础配置 ----------

# Dimens 后端 API 基础地址
# 默认 http://127.0.0.1:8001
# 生产环境需改为实际的线上地址
DIMENS_BASE_URL=https://dimens.bintelai.com/api

# ---------- 团队与项目上下文 ----------

# 团队 ID（必填）
# 用于 SDK 调用时的团队隔离边界
# 可在 Dimens 后台「团队设置」中获取
DIMENS_TEAM_ID=your_team_id

# 项目 ID（必填）
# 用于 SDK 调用时的项目上下文标识
# 可在 Dimens 后台「项目设置」中获取
DIMENS_PROJECT_ID=your_project_id

# ---------- 市场接口配置 ----------

# 维表智联市场 API 基础 URL（可选）
# 默认与 DIMENS_BASE_URL 一致，生产环境可单独指定
# DIMENS_MARKET_BASE_URL=https://dimens.bintelai.com/api

# 维表智联市场接口 Token（可选）
# 用于调用 open/market/* 等公开市场资源接口
# DIMENS_MARKET_TOKEN=your_market_token

